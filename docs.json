{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Kalixo API",
  "description": "Developer documentation for the Kalixo Distribution API v2 - catalog, ordering, and wallet.",
  "colors": {
    "primary": "#799423",
    "light": "#c9f73a",
    "dark": "#a1c62e"
  },
  "appearance": {
    "default": "dark",
    "strict": false
  },
  "background": {
    "color": {
      "light": "#ffffff",
      "dark": "#0a0c03"
    }
  },
  "logo": {
    "light": "/logo/kalixo-black.svg",
    "dark": "/logo/kalixo-white.svg",
    "href": "https://developer.kalixo.io"
  },
  "favicon": "/favicon.ico",
  "styling": {
    "eyebrows": "section",
    "codeblocks": "dark"
  },
  "navbar": {
    "links": [
      {
        "label": "Support",
        "href": "mailto:integrations@kalixo.io"
      },
      {
        "label": "Status",
        "href": "https://status.kalixo.io"
      },
      {
        "label": "Postman",
        "href": "/kalixo-api-v2.postman_collection.json"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Get an API key",
      "href": "mailto:integrations@kalixo.io"
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Guides",
        "groups": [
          {
            "group": "Get started",
            "pages": ["index", "quickstart", "authentication", "concepts/sandbox", "changelog"]
          },
          {
            "group": "Core concepts",
            "pages": [
              "concepts/pagination",
              "concepts/filtering",
              "concepts/open-denomination",
              "concepts/order-lifecycle",
              "concepts/order-cancellation",
              "concepts/idempotency",
              "concepts/rate-limits",
              "concepts/errors",
              "concepts/notifications",
              "concepts/webhooks",
              "examples/kalixo-node"
            ]
          },
          {
            "group": "Migrate",
            "pages": ["migrating-from-v1"]
          }
        ]
      },
      {
        "tab": "API reference",
        "groups": [
          {
            "group": "Overview",
            "pages": ["api-reference/introduction"]
          },
          {
            "group": "Endpoints",
            "openapi": "openapi.json"
          }
        ]
      }
    ]
  },
  "api": {
    "playground": {
      "display": "interactive"
    },
    "examples": {
      "languages": ["bash", "javascript", "python", "php"]
    }
  },
  "contextual": {
    "options": ["copy", "view", "chatgpt", "claude", "download-spec"]
  },
  "search": {
    "prompt": "Search the Kalixo API docs"
  },
  "footer": {
    "socials": {
      "website": "https://kalixo.io",
      "linkedin": "https://www.linkedin.com/company/kalixo"
    }
  }
}
